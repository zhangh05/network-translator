# ── LLM Provider ──
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.com/anthropic
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT=45

# ── API Authentication ──
# If set, all API routes require X-API-Secret header
API_SECRET=

# ── HTTP Server ──
HOST=0.0.0.0
PORT=5008
WORKERS=4

# ── Logging ──
LOG_LEVEL=info

# ── Flask Dev (optional) ──
# FLASK_DEBUG=1
